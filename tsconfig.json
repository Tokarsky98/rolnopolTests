{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@_src/*": ["./src/*"],
      "@_api/*": ["./src/api/*"],
      "@_ui/*": ["./src/ui/*"],
      "@_config/*": ["./config/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "config/**/*.ts",
    "playwright.config.ts",
    "eslint.config.mjs"
  ]
}
